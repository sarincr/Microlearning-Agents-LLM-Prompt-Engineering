        "\"\"\"\n",
        "Secure SQL Handshake System\n",
        "===========================\n",
        "\n",
        "Purpose:\n",
        "--------\n",
        "This module implements a dual-agent SQL execution pipeline with strict policy enforcement.\n",
        "It uses two LLMs:\n",
        "    - Coder (Llama 3.2): Generates SQL queries from natural language requests.\n",
        "    - Auditor (Qwen 2.5): Reviews generated SQL against a configurable security policy.\n",
        "\n",
        "Architecture:\n",
        "-------------\n",
        "1. User request arrives.\n",
        "2. Coder generates SQL.\n",
        "3. Auditor checks SQL against policy.\n",
        "4. Gatekeeper decides whether to execute or reject.\n",
        "5. Audit trail is recorded in a dedicated audit database.\n",
        "\n",
        "Usage:\n",
        "------\n",
        "    system = SecureSQLHandshake()\n",
        "    result = system.handle_request(\"Delete Bob from the system.\")\n",
        "    print(result)\n",
        "\n",
        "Configuration:\n",
        "--------------\n",
        "Environment variables allow customization:\n",
        "    CODER_MODEL       -> default \"llama3.2\"\n",
        "    AUDITOR_MODEL     -> default \"qwen2.5:0.5b\"\n",
        "    DB_PATH           -> default \"security_demo.db\"\n",
        "    AUDIT_DB_PATH     -> default \"audit_log.db\"\n",
        "    MAX_RETRIES       -> default 3\n",
        "    LOG_PATH          -> default \"audit.log\"\n",
        "\"\"\"\n",
        "\n",
        "import os\n",
        "import re\n",
        "import sqlite3\n",
        "import logging\n",
        "from logging.handlers import RotatingFileHandler\n",
        "from datetime import datetime\n",
        "from typing import Dict, Any, Optional\n",
        "from langchain_ollama import ChatOllama\n",
        "from langchain_community.tools.sql_database.tool import QuerySQLDataBaseTool\n",
        "from langchain_community.utilities import SQLDatabase\n",
        "\n",
        "\n",
        "class SecureSQLHandshake:\n",
        "    \"\"\"Encapsulates secure SQL generation, auditing, and execution.\"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        # --- Configuration via environment variables ---\n",
        "        self.coder_model = os.getenv(\"CODER_MODEL\", \"llama3.2\")\n",
        "        self.auditor_model = os.getenv(\"AUDITOR_MODEL\", \"qwen2.5:0.5b\")\n",
        "        self.db_path = os.getenv(\"DB_PATH\", \"security_demo.db\")\n",
        "        self.audit_db_path = os.getenv(\"AUDIT_DB_PATH\", \"audit_log.db\")\n",
        "        self.max_retries = int(os.getenv(\"MAX_RETRIES\", \"3\"))\n",
        "        self.log_path = os.getenv(\"LOG_PATH\", \"audit.log\")\n",
        "\n",
        "        # --- Logging setup: console + rotating file ---\n",
        "        self.logger = logging.getLogger(\"SecureSQLHandshake\")\n",
        "        self.logger.setLevel(logging.INFO)\n",
        "        formatter = logging.Formatter(\"%(asctime)s [%(levelname)s] %(message)s\")\n",
        "\n",
        "        console_handler = logging.StreamHandler()\n",
        "        console_handler.setFormatter(formatter)\n",
        "\n",
        "        file_handler = RotatingFileHandler(self.log_path, maxBytes=1_000_000, backupCount=3)\n",
        "        file_handler.setFormatter(formatter)\n",
        "\n",
        "        self.logger.addHandler(console_handler)\n",
        "        self.logger.addHandler(file_handler)\n",
        "\n",
        "        # --- Models ---\n",
        "        self.coder_llm = ChatOllama(model=self.coder_model, temperature=0)\n",
        "        self.auditor_llm = ChatOllama(model=self.auditor_model, temperature=0)\n",
        "\n",
        "        # --- Database setup ---\n",
        "        self._setup_demo_db()\n",
        "        self.db = SQLDatabase.from_uri(f\"sqlite:///{self.db_path}\")\n",
        "        self.executor = QuerySQLDataBaseTool(db=self.db)\n",
        "\n",
        "        # --- Audit database setup ---\n",
        "        self._setup_audit_db()\n",
        "\n",
        "        # --- Policy ---\n",
        "        self.policy_doc = \"\"\"\n",
        "        POLICY:\n",
        "        - DELETE statements are forbidden.\n",
        "        - DROP and ALTER statements are forbidden.\n",
        "        - Removals must use: UPDATE employees SET status = 'Inactive' WHERE ...\n",
        "        \"\"\"\n",
        "\n",
        "    def _setup_demo_db(self) -> None:\n",
        "        \"\"\"Create demo employees table with resource cleanup.\"\"\"\n",
        "        conn = sqlite3.connect(self.db_path)\n",
        "        try:\n",
        "            conn.execute(\"DROP TABLE IF EXISTS employees\")\n",
        "            conn.execute(\"CREATE TABLE employees (id INTEGER PRIMARY KEY, name TEXT, status TEXT DEFAULT 'Active')\")\n",
        "            conn.executemany(\"INSERT INTO employees (name) VALUES (?)\", [('Alice',), ('Bob',)])\n",
        "            conn.commit()\n",
        "        finally:\n",
        "            conn.close()\n",
        "\n",
        "    def _setup_audit_db(self) -> None:\n",
        "        \"\"\"Create audit database with request and violation tables.\"\"\"\n",
        "        conn = sqlite3.connect(self.audit_db_path)\n",
        "        try:\n",
        "            conn.execute(\"\"\"\n",
        "                CREATE TABLE IF NOT EXISTS audit_requests (\n",
        "                    id INTEGER PRIMARY KEY AUTOINCREMENT,\n",
        "                    timestamp TEXT,\n",
        "                    user_request TEXT,\n",
        "                    generated_sql TEXT,\n",
        "                    audit_result TEXT,\n",
        "                    execution_result TEXT,\n",
        "                    coder_model TEXT,\n",
        "                    auditor_model TEXT,\n",
        "                    duration_ms INTEGER\n",
        "                )\n",
        "            \"\"\")\n",
        "            conn.execute(\"\"\"\n",
        "                CREATE TABLE IF NOT EXISTS audit_policy_violations (\n",
        "                    id INTEGER PRIMARY KEY AUTOINCREMENT,\n",
        "                    request_id INTEGER,\n",
        "                    violation_reason TEXT,\n",
        "                    FOREIGN KEY(request_id) REFERENCES audit_requests(id)\n",
        "                )\n",
        "            \"\"\")\n",
        "            conn.commit()\n",
        "        finally:\n",
        "            conn.close()\n",
        "\n",
        "    def _extract_sql(self, raw_output: str) -> str:\n",
        "        \"\"\"Safely extract first SQL statement using regex.\"\"\"\n",
        "        sql_match = re.search(r\"(SELECT|UPDATE|INSERT|DELETE|DROP|ALTER).*?;\", raw_output, re.IGNORECASE | re.DOTALL)\n",
        "        return sql_match.group(0).strip() if sql_match else raw_output.strip()\n",
        "\n",
        "    def handle_request(self, user_request: str) -> Dict[str, Any]:\n",
        "        \"\"\"\n",
        "        Process a user request securely.\n",
        "\n",
        "        Args:\n",
        "            user_request (str): Natural language request.\n",
        "\n",
        "        Returns:\n",
        "            Dict[str, Any]: Structured result with audit details.\n",
        "        \"\"\"\n",
        "        self.logger.info(f\"Request received: {user_request}\")\n",
        "        start_time = datetime.now()\n",
        "\n",
        "        generated_sql = None\n",
        "        audit_result = None\n",
        "        execution_result: Optional[str] = None\n",
        "        violation_reason: Optional[str] = None\n",
        "\n",
        "        # --- Retry loop for SQL generation ---\n",
        "        for attempt in range(self.max_retries):\n",
        "            try:\n",
        "                coder_prompt = f\"Policy: {self.policy_doc}\\nSchema: {self.db.get_table_info()}\\nTask: {user_request}\\nReturn ONLY the SQL code.\"\n",
        "                raw_sql = self.coder_llm.invoke(coder_prompt).content\n",
        "                generated_sql = self._extract_sql(raw_sql)\n",
        "                self.logger.info(f\"Generated SQL (attempt {attempt+1}): {generated_sql}\")\n",
        "                break\n",
        "            except Exception as e:\n",
        "                self.logger.error(f\"SQL generation failed (attempt {attempt+1}): {e}\")\n",
        "        else:\n",
        "            return {\"status\": \"error\", \"message\": \"SQL generation failed after retries.\"}\n",
        "\n",
        "        # --- Audit step ---\n",
        "        audit_prompt = f\"\"\"\n",
        "        Check this SQL against the Security Policy.\n",
        "        POLICY: {self.policy_doc}\n",
        "        SQL: {generated_sql}\n",
        "\n",
        "        If it contains DELETE/DROP/ALTER, respond 'REJECTED'.\n",
        "        If it uses UPDATE employees SET status, respond 'APPROVED'.\n",
        "        Output one word only.\n",
        "        \"\"\"\n",
        "        try:\n",
        "            audit_result = self.auditor_llm.invoke(audit_prompt).content.strip().upper()\n",
        "            self.logger.info(f\"Audit Result: {audit_result}\")\n",
        "        except Exception as e:\n",
        "            self.logger.error(f\"Audit failed: {e}\")\n",
        "            return {\"status\": \"error\", \"message\": \"Audit failed.\"}\n",
        "\n",
        "        # --- Gatekeeper logic ---\n",
        "        if \"APPROVED\" in audit_result:\n",
        "            try:\n",
        "                execution_result = self.executor.invoke(generated_sql)\n",
        "                self.logger.info(f\"Execution Result: {execution_result}\")\n",
        "            except Exception as e:\n",
        "                execution_result = f\"ERROR: {str(e)}\"\n",
        "                self.logger.error(execution_result)\n",
        "        else:\n",
        "            violation_reason = \"Policy violation detected\"\n",
        "            self.logger.warning(violation_reason)\n",
        "\n",
        "        # --- Audit trail recording ---\n",
        "        duration_ms = int((datetime.now() - start_time).total_seconds() * 1000)\n",
        "        conn = sqlite3.connect(self.audit_db_path)\n",
        "        try:\n",
        "            cursor = conn.cursor()\n",
        "            cursor.execute(\"\"\"\n",
        "                INSERT INTO audit_requests (timestamp, user_request, generated_sql, audit_result, execution_result, coder_model, auditor_model, duration_ms)\n",
        "                VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n",
        "            \"\"\", (datetime.now().isoformat(), user_request, generated_sql, audit_result, str(execution_result), self.coder_model, self.auditor_model, duration_ms))\n",
        "            request_id = cursor.lastrowid\n",
        "\n",
        "            if violation_reason:\n",
        "                cursor.execute(\"INSERT INTO audit_policy_violations (request_id, violation_reason) VALUES (?, ?)\", (request_id, violation_reason))\n",
        "\n",
        "            conn.commit()\n",
        "        finally:\n",
        "            conn.close()\n",
        "\n",
        "        # --- Return structured result ---\n",
        "        return {\n",
        "            \"status\": \"success\" if \"APPROVED\" in audit_result else \"rejected\",\n",
        "            \"user_request\": user_request,\n",
        "            \"generated_sql\": generated_sql,\n",
        "            \"audit_result\": audit_result,\n",
        "            \"execution_result\": execution_result,\n",
        "            \"duration_ms\": duration_ms\n",
        "        }\n",
        "\n",
        "    def close(self) -> None:\n",
        "        \"\"\"Release resources and close connections.\"\"\"\n",
        "        self.logger.info(\"Closing SecureSQLHandshake system.\")\n",
        "\n",
