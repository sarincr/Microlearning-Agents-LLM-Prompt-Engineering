      "source": [
        "# =============================================================================\n",
        "# SECURE SQL HANDLER – COLAB NATIVE (FULLY FIXED)\n",
        "# =============================================================================\n",
        "# Features: Dual-agent, auto model pull, policy enforcement, full audit trail,\n",
        "# UUID tracking, SQL sanitisation, retries, timeouts, input validation, HTML report.\n",
        "# =============================================================================\n",
        "\n",
        "!pip install -q langchain-community langchain-ollama\n",
        "\n",
        "import json\n",
        "import logging\n",
        "import logging.handlers\n",
        "import os\n",
        "import re\n",
        "import signal\n",
        "import sqlite3\n",
        "import subprocess\n",
        "import sys\n",
        "import time\n",
        "import uuid\n",
        "from datetime import datetime, timezone\n",
        "from pathlib import Path\n",
        "from typing import Dict, Optional, Tuple, Any\n",
        "\n",
        "from langchain_ollama import ChatOllama\n",
        "from langchain_community.tools.sql_database.tool import QuerySQLDataBaseTool\n",
        "from langchain_community.utilities import SQLDatabase\n",
        "\n",
        "# -----------------------------------------------------------------------------\n",
        "# Configuration\n",
        "# -----------------------------------------------------------------------------\n",
        "CONFIG_FILE = \"config.json\"\n",
        "DEFAULT_CONFIG = {\n",
        "    \"db\": {\"main_path\": \"security_demo.db\", \"audit_path\": \"audit_log.db\"},\n",
        "    \"models\": {\"coder\": \"llama3.2\", \"auditor\": \"qwen2.5:0.5b\", \"temperature\": 0.0},\n",
        "    \"logging\": {\"level\": \"INFO\", \"file\": \"secure_sql.log\", \"max_bytes\": 1048576, \"backup_count\": 5, \"json_lines\": False},\n",
        "    \"execution\": {\"timeout_seconds\": 30, \"max_retries\": 2, \"retry_backoff_base\": 0.5},\n",
        "    \"policy\": {\"forbidden_keywords\": [\"DELETE\", \"DROP\", \"TRUNCATE\", \"INSERT\", \"ALTER\"], \"allowed_pattern\": \"UPDATE employees SET status = 'Inactive'\"},\n",
        "    \"input_limits\": {\"max_request_length\": 500, \"max_sql_length\": 2000}\n",
        "}\n",
        "\n",
        "def load_config() -> Dict:\n",
        "    config = DEFAULT_CONFIG.copy()\n",
        "    if Path(CONFIG_FILE).exists():\n",
        "        with open(CONFIG_FILE) as f:\n",
        "            file_config = json.load(f)\n",
        "            for k, v in file_config.items():\n",
        "                if isinstance(v, dict) and k in config:\n",
        "                    config[k].update(v)\n",
        "                else:\n",
        "                    config[k] = v\n",
        "    return config\n",
        "\n",
        "class SecureSQLHandler:\n",
        "    def __init__(self, config: Optional[Dict] = None):\n",
        "        self.config = config or load_config()\n",
        "        self._setup_logging()\n",
        "        self.logger = logging.getLogger(__name__)\n",
        "        self.logger.info(\"Initializing SecureSQLHandler\")\n",
        "\n",
        "        self._ensure_ollama()\n",
        "        self._ensure_models()\n",
        "        self._setup_databases()\n",
        "        self._init_llms()\n",
        "        self._init_audit_db()\n",
        "        self._running = True\n",
        "        try:\n",
        "            signal.signal(signal.SIGINT, self._shutdown)\n",
        "        except ValueError:\n",
        "            pass\n",
        "\n",
        "    def _setup_logging(self) -> None:\n",
        "        log_cfg = self.config[\"logging\"]\n",
        "        level = getattr(logging, log_cfg[\"level\"].upper())\n",
        "        root = logging.getLogger()\n",
        "        root.setLevel(level)\n",
        "        console = logging.StreamHandler(sys.stdout)\n",
        "        console.setFormatter(logging.Formatter('%(asctime)s | %(levelname)-8s | %(name)s | %(message)s'))\n",
        "        root.addHandler(console)\n",
        "        file_handler = logging.handlers.RotatingFileHandler(\n",
        "            log_cfg[\"file\"], maxBytes=log_cfg[\"max_bytes\"], backupCount=log_cfg[\"backup_count\"]\n",
        "        )\n",
        "        file_handler.setFormatter(logging.Formatter('%(asctime)s | %(levelname)-8s | %(name)s | %(message)s'))\n",
        "        root.addHandler(file_handler)\n",
        "\n",
        "    def _ensure_ollama(self) -> None:\n",
        "        # Install if missing\n",
        "        try:\n",
        "            subprocess.run([\"ollama\", \"--version\"], capture_output=True, check=True)\n",
        "            self.logger.info(\"Ollama already installed.\")\n",
        "        except:\n",
        "            self.logger.warning(\"Installing Ollama...\")\n",
        "            subprocess.run(\"curl -fsSL https://ollama.com/install.sh | sh\", shell=True, check=True)\n",
        "            time.sleep(2)\n",
        "        # Kill existing server and restart cleanly\n",
        "        subprocess.run(\"pkill ollama\", shell=True, stderr=subprocess.DEVNULL)\n",
        "        time.sleep(1)\n",
        "        self.ollama_process = subprocess.Popen([\"ollama\", \"serve\"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)\n",
        "        for _ in range(30):\n",
        "            try:\n",
        "                subprocess.run([\"ollama\", \"list\"], capture_output=True, check=True)\n",
        "                self.logger.info(\"Ollama server ready.\")\n",
        "                return\n",
        "            except:\n",
        "                time.sleep(1)\n",
        "        self.logger.error(\"Ollama server failed to start.\")\n",
        "        sys.exit(1)\n",
        "\n",
        "    def _ensure_models(self) -> None:\n",
        "        for model in [self.config[\"models\"][\"coder\"], self.config[\"models\"][\"auditor\"]]:\n",
        "            self.logger.info(\"Pulling %s...\", model)\n",
        "            subprocess.run([\"ollama\", \"pull\", model], capture_output=True, check=False)\n",
        "\n",
        "    def _setup_databases(self) -> None:\n",
        "        main_path = self.config[\"db\"][\"main_path\"]\n",
        "        conn = sqlite3.connect(main_path)\n",
        "        conn.execute(\"DROP TABLE IF EXISTS employees\")\n",
        "        conn.execute(\"CREATE TABLE employees (id INTEGER PRIMARY KEY, name TEXT NOT NULL, status TEXT DEFAULT 'Active')\")\n",
        "        conn.executemany(\"INSERT INTO employees (name) VALUES (?)\", [('Alice',), ('Bob',)])\n",
        "        conn.commit()\n",
        "        conn.close()\n",
        "        self.db = SQLDatabase.from_uri(f\"sqlite:///{main_path}\")\n",
        "        self.executor = QuerySQLDataBaseTool(db=self.db)\n",
        "\n",
        "    def _init_llms(self) -> None:\n",
        "        model_cfg = self.config[\"models\"]\n",
        "        self.coder_llm = ChatOllama(model=model_cfg[\"coder\"], temperature=model_cfg[\"temperature\"])\n",
        "        self.auditor_llm = ChatOllama(model=model_cfg[\"auditor\"], temperature=model_cfg[\"temperature\"])\n",
        "\n",
        "    def _init_audit_db(self) -> None:\n",
        "        audit_path = self.config[\"db\"][\"audit_path\"]\n",
        "        self.audit_conn = sqlite3.connect(audit_path)\n",
        "        cursor = self.audit_conn.cursor()\n",
        "        cursor.execute(\"DROP TABLE IF EXISTS audit_requests\")\n",
        "        cursor.execute(\"DROP TABLE IF EXISTS audit_violations\")\n",
        "        cursor.execute(\"\"\"\n",
        "            CREATE TABLE audit_requests (\n",
        "                id TEXT PRIMARY KEY,\n",
        "                timestamp TEXT,\n",
        "                user_request TEXT,\n",
        "                generated_sql TEXT,\n",
        "                audit_decision TEXT,\n",
        "                execution_success INTEGER,\n",
        "                error_message TEXT,\n",
        "                execution_time_ms INTEGER,\n",
        "                coder_model TEXT,\n",
        "                auditor_model TEXT\n",
        "            )\n",
        "        \"\"\")\n",
        "        cursor.execute(\"\"\"\n",
        "            CREATE TABLE audit_violations (\n",
        "                id INTEGER PRIMARY KEY AUTOINCREMENT,\n",
        "                request_id TEXT,\n",
        "                violation_reason TEXT,\n",
        "                FOREIGN KEY(request_id) REFERENCES audit_requests(id)\n",
        "            )\n",
        "        \"\"\")\n",
        "        self.audit_conn.commit()\n",
        "        self.logger.info(\"Audit database ready.\")\n",
        "\n",
        "    def _validate_input(self, user_request: str) -> Tuple[bool, str]:\n",
        "        if len(user_request) > self.config[\"input_limits\"][\"max_request_length\"]:\n",
        "            return False, \"Request too long\"\n",
        "        dangerous = [\"--\", \";\", \"/*\", \"*/\", \"xp_\", \"exec \"]\n",
        "        if any(d in user_request.lower() for d in dangerous):\n",
        "            return False, \"Suspicious pattern detected\"\n",
        "        return True, \"\"\n",
        "\n",
        "    def _extract_sql(self, raw: str) -> str:\n",
        "        cleaned = re.sub(r\"```sql\\n?|```\", \"\", raw, flags=re.IGNORECASE)\n",
        "        cleaned = re.sub(r\"--.*$\", \"\", cleaned, flags=re.MULTILINE)\n",
        "        statements = [s.strip() for s in cleaned.split(';') if s.strip()]\n",
        "        if not statements:\n",
        "            raise ValueError(\"No SQL found\")\n",
        "        first_sql = statements[0]\n",
        "        if len(first_sql) > self.config[\"input_limits\"][\"max_sql_length\"]:\n",
        "            raise ValueError(\"SQL too long\")\n",
        "        return first_sql + ';'\n",
        "\n",
        "    def _audit_sql(self, sql: str) -> Tuple[str, str]:\n",
        "        if re.search(r'\\bDELETE\\b|\\bDROP\\b|\\bINSERT\\b', sql, re.IGNORECASE):\n",
        "            return \"REJECTED\", \"Forbidden keyword\"\n",
        "        if \"update employees set status = 'inactive'\" not in sql.lower():\n",
        "            return \"REJECTED\", \"Only UPDATE status='Inactive' allowed\"\n",
        "        try:\n",
        "            response = self.auditor_llm.invoke(f\"Approve or reject this SQL: {sql}\").content.strip().upper()\n",
        "            return (response if response in (\"APPROVED\",\"REJECTED\") else \"REJECTED\"), \"\"\n",
        "        except:\n",
        "            return \"REJECTED\", \"Auditor error\"\n",
        "\n",
        "    def _execute_safely(self, sql: str) -> Tuple[bool, str]:\n",
        "        if not sql.lower().startswith(\"update\"):\n",
        "            return False, \"Only UPDATE allowed\"\n",
        "        try:\n",
        "            result = self.executor.invoke(sql, timeout=self.config[\"execution\"][\"timeout_seconds\"])\n",
        "            return True, str(result)\n",
        "        except Exception as e:\n",
        "            return False, str(e)\n",
        "\n",
        "    def handle_request(self, user_request: str) -> Dict[str, Any]:\n",
        "        req_id = str(uuid.uuid4())\n",
        "        self.logger.info(\"Request %s: %s\", req_id, user_request)\n",
        "        start = time.perf_counter()\n",
        "\n",
        "        valid, err = self._validate_input(user_request)\n",
        "        if not valid:\n",
        "            self._audit_log(req_id, user_request, \"\", \"INVALID_INPUT\", False, err, 0)\n",
        "            return {\"success\": False, \"message\": err, \"request_id\": req_id}\n",
        "\n",
        "        # Generate SQL with retries\n",
        "        sql = None\n",
        "        for attempt in range(1, self.config[\"execution\"][\"max_retries\"] + 1):\n",
        "            try:\n",
        "                prompt = f\"Schema: {self.db.get_table_info()}\\nUser: {user_request}\\nGenerate only SQL using UPDATE employees SET status='Inactive' WHERE...\"\n",
        "                raw = self.coder_llm.invoke(prompt).content\n",
        "                sql = self._extract_sql(raw)\n",
        "                break\n",
        "            except Exception as e:\n",
        "                self.logger.warning(\"Attempt %d failed: %s\", attempt, e)\n",
        "                if attempt == self.config[\"execution\"][\"max_retries\"]:\n",
        "                    self._audit_log(req_id, user_request, \"\", \"GENERATION_FAILED\", False, str(e), 0)\n",
        "                    return {\"success\": False, \"message\": f\"Generation failed: {e}\", \"request_id\": req_id}\n",
        "                time.sleep(self.config[\"execution\"][\"retry_backoff_base\"] * (2 ** attempt))\n",
        "\n",
        "        decision, reason = self._audit_sql(sql)\n",
        "        if decision == \"REJECTED\":\n",
        "            self._audit_log(req_id, user_request, sql, \"REJECTED\", False, reason, 0)\n",
        "            self._log_violation(req_id, reason)\n",
        "            return {\"success\": False, \"message\": f\"Policy violation: {reason}\", \"sql\": sql, \"request_id\": req_id}\n",
        "\n",
        "        exec_ok, exec_msg = self._execute_safely(sql)\n",
        "        exec_ms = int((time.perf_counter() - start) * 1000)\n",
        "        self._audit_log(req_id, user_request, sql, \"APPROVED\", exec_ok, exec_msg if not exec_ok else None, exec_ms)\n",
        "\n",
        "        if exec_ok:\n",
        "            final_state = self.db.run(\"SELECT * FROM employees\")\n",
        "            self.logger.info(\"Success. Final table: %s\", final_state)\n",
        "            return {\"success\": True, \"message\": \"Executed\", \"sql\": sql, \"result\": exec_msg, \"request_id\": req_id}\n",
        "        else:\n",
        "            return {\"success\": False, \"message\": f\"Execution error: {exec_msg}\", \"sql\": sql, \"request_id\": req_id}\n",
        "\n",
        "    def _audit_log(self, req_id, user_req, sql, decision, exec_ok, error, exec_ms):\n",
        "        self.audit_conn.execute(\"\"\"\n",
        "            INSERT OR REPLACE INTO audit_requests\n",
        "            (id, timestamp, user_request, generated_sql, audit_decision, execution_success, error_message, execution_time_ms, coder_model, auditor_model)\n",
        "            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n",
        "        \"\"\", (req_id, datetime.now(timezone.utc).isoformat(), user_req, sql, decision,\n",
        "              1 if exec_ok else 0, error, exec_ms,\n",
        "              self.config[\"models\"][\"coder\"], self.config[\"models\"][\"auditor\"]))\n",
        "        self.audit_conn.commit()\n",
        "\n",
        "    def _log_violation(self, req_id, reason):\n",
        "        self.audit_conn.execute(\"INSERT INTO audit_violations (request_id, violation_reason) VALUES (?, ?)\", (req_id, reason))\n",
        "        self.audit_conn.commit()\n",
        "\n",
        "    def generate_report(self, output_file=\"audit_report.html\"):\n",
        "        cursor = self.audit_conn.cursor()\n",
        "        cursor.execute(\"SELECT * FROM audit_requests ORDER BY timestamp DESC LIMIT 100\")\n",
        "        rows = cursor.fetchall()\n",
        "        html = \"<html><head><title>SQL Audit Report</title></head><body><h1>Recent Requests</h1><table border='1'><tr><th>ID</th><th>Time</th><th>Request</th><th>Decision</th><th>Success</th></tr>\"\n",
        "        for row in rows:\n",
        "            html += f\"<tr><td>{row[0]}</td><td>{row[1]}</td><td>{row[2][:50]}</td><td>{row[4]}</td><td>{row[5]}</td></tr>\"\n",
        "        html += \"</table></body></html>\"\n",
        "        Path(output_file).write_text(html)\n",
        "        self.logger.info(\"Report saved to %s\", output_file)\n",
        "\n",
        "    def _shutdown(self, signum=None, frame=None):\n",
        "        self.logger.info(\"Shutting down...\")\n",
        "        if hasattr(self, 'audit_conn'):\n",
        "            self.audit_conn.close()\n",
        "        if hasattr(self, 'ollama_process'):\n",
        "            self.ollama_process.terminate()\n",
        "        sys.exit(0)\n",
        "\n",
        "# -----------------------------------------------------------------------------\n",
        "# Run Demo\n",
        "# -----------------------------------------------------------------------------\n",
        "if __name__ == \"__main__\":\n",
        "    handler = SecureSQLHandler()\n",
        "    try:\n",
        "        r1 = handler.handle_request(\"Delete Bob from the system.\")\n",
        "        print(\"\\n=== VIOLATION ===\\n\", json.dumps(r1, indent=2))\n",
        "        r2 = handler.handle_request(\"Mark Bob as inactive\")\n",
        "        print(\"\\n=== COMPLIANT ===\\n\", json.dumps(r2, indent=2))\n",
        "        handler.generate_report()\n",
        "        print(\"\\n✅ Report: audit_report.html\")\n",
        "    except KeyboardInterrupt:\n",
        "        handler._shutdown()"
      ],
